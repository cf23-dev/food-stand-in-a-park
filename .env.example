# ─────────────────────────────────────────────────────────────────────────────
# Food Stand in a Park — environment variables
# Copy this file to `.env.local` for local dev and fill in real values.
# In Vercel, add each of these under Project Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase ────────────────────────────────────────────────────────────────────
# Project Settings → API in the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key — SERVER ONLY. Never expose to the browser.
# Used by API routes for privileged inserts (donor requests, volunteer notify).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Maps (OPTIONAL — leave blank to use free OpenStreetMap geocoding) ──────
# console.cloud.google.com → enable Maps JavaScript API, Places API,
# Geocoding API, Directions API, Distance Matrix API.
# Restrict the browser key by HTTP referrer; restrict the server key by IP/API.
# IMPORTANT: leave these EMPTY (not placeholder text) if you're not using them.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=
GOOGLE_MAPS_SERVER_KEY=

# Email (Resend) (OPTIONAL — leave blank to log emails to the server console) ───
# resend.com → API Keys. Verify a sending domain for production.
RESEND_API_KEY=
EMAIL_FROM=

# App ─────────────────────────────────────────────────────────────────────────
# Public base URL, used in confirmation/notification emails.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Default radius (miles) for notifying volunteers about new pickups.
NEXT_PUBLIC_DEFAULT_NOTIFY_RADIUS_MILES=10

# Shared secret between the scheduled reminder job (GitHub Actions) and the
# /api/cron/reminders endpoint. Use a long random string; set the SAME value as
# a GitHub Actions repository secret named CRON_SECRET.
CRON_SECRET=your-long-random-string

# Where donor feedback notifications are emailed (server only).
ADMIN_EMAIL=you@example.org
